generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id      String  @id @default(cuid())
  name    String
  appName String  @default("Flipdeck")
  tagline String?
  email   String?
  phone   String?
  address String?
  logoUrl String? // object storage URL (R2) — never base64
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  OWNER
  PARTNER
  PARTNER_LENDER
  BOOKKEEPER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  phone     String?
  role      Role     @default(PARTNER)
  partnerId String?  @unique // links a login to a capital-ledger identity
  partner   Partner? @relation(fields: [partnerId], references: [id])

  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]
}

model Partner {
  id            String         @id @default(cuid())
  name          String
  user          User?
  contributions Contribution[]
}

enum Status {
  SCOUTING
  UNDER_CONTRACT
  IN_REHAB
  // The buy-and-hold exit: rehab finishes and the property is kept and let out
  // instead of listed. Still a held asset — only SOLD leaves the balance sheet.
  RENTED
  LISTED
  IN_ESCROW
  SOLD
}

model Property {
  id       String  @id @default(cuid())
  address  String
  mls      String?
  type     String // Single Family, Condo, ...
  beds     Float
  baths    Float
  sqft     Int
  lotSize  Int
  stories  Int
  photoUrl String?
  status   Status  @default(SCOUTING)

  // Balance-sheet fields, both user-maintained. marketValue is the current
  // ARV/appraisal; when blank the company dashboard falls back to the
  // budget's estimated Sale Price. monthlyRent is rental income for held
  // properties (ignored once SOLD).
  marketValue Decimal? @db.Decimal(12, 2)
  monthlyRent Decimal? @db.Decimal(12, 2)

  budget        BudgetLine[]
  expenses      Expense[]
  income        Income[]
  payroll       PayrollEntry[]
  contributions Contribution[]
  bankTxns      BankTxn[]
  liabilities   Liability[]
}

model BudgetLine {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  category    String // one of the 5 categories
  subcategory String
  estimated   Decimal  @db.Decimal(12, 2)
  actual      Decimal  @default(0) @db.Decimal(12, 2)
  updatedAt   DateTime @updatedAt

  @@unique([propertyId, subcategory])
}

enum ExpenseStatus {
  PENDING
  PAID
  REIMBURSED
}

model Expense {
  id          String        @id @default(cuid())
  date        DateTime      @db.Date
  propertyId  String
  property    Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amount      Decimal       @db.Decimal(12, 2)
  description String
  subcategory String
  status      ExpenseStatus @default(PENDING)
  receiptUrl  String?
  bankTxnId   String?       @unique // set when created by reconciling a bank txn
  bankTxn     BankTxn?      @relation(fields: [bankTxnId], references: [id])
}

enum TxnDirection {
  IN
  OUT
}

model BankTxn {
  id          String       @id @default(cuid())
  date        DateTime     @db.Date
  description String
  // Always POSITIVE — `direction` carries the sign. OUT posts to an Expense,
  // IN posts to an Income; together they derive cash on hand.
  amount      Decimal      @db.Decimal(12, 2)
  direction   TxnDirection @default(OUT)
  accountId   String
  bankAccount BankAccount  @relation(fields: [accountId], references: [id])
  propertyId  String?
  property    Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  subcategory String?
  reconciled  Boolean      @default(false)
  expense     Expense?
  income      Income?
  // accountId|date|amount|direction|normalized-description — direction and
  // account are both in the key so an IN/OUT pair (or the same statement
  // imported into two accounts) can't wrongly dedupe against each other.
  importHash  String       @unique
}

// A real bank account. Balance is DERIVED (openingBalance + Σin − Σout),
// never stored, so it can't drift from the transactions behind it.
model BankAccount {
  id             String    @id @default(cuid())
  name           String    @unique // "Chase •4471"
  openingBalance Decimal   @default(0) @db.Decimal(12, 2)
  notes          String?
  updatedAt      DateTime  @updatedAt
  transactions   BankTxn[]
}

enum IncomeCategory {
  RENT
  SALE_PROCEEDS
  REFUND
  OTHER
}

// Money IN, mirroring Expense. Property.monthlyRent is the EXPECTED recurring
// rent; these rows are what was ACTUALLY received — the same estimated-vs-actual
// split used elsewhere in the app.
model Income {
  id          String         @id @default(cuid())
  date        DateTime       @db.Date
  propertyId  String
  property    Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amount      Decimal        @db.Decimal(12, 2)
  description String
  category    IncomeCategory @default(RENT)
  bankTxnId   String?        @unique // set when created by posting a bank deposit
  bankTxn     BankTxn?       @relation(fields: [bankTxnId], references: [id])
}

model Worker {
  id          String         @id @default(cuid())
  name        String         @unique
  defaultRate Decimal?       @db.Decimal(8, 2)
  payroll     PayrollEntry[]
}

model PayrollEntry {
  id         String   @id @default(cuid())
  date       DateTime @db.Date
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  workerId   String
  worker     Worker   @relation(fields: [workerId], references: [id])
  hours      Decimal  @db.Decimal(8, 2)
  rate       Decimal  @db.Decimal(8, 2)
  notes      String?
  // total is COMPUTED (hours × rate) — never store it
}

enum ContribKind {
  EQUITY
  LOAN
  DRAW
}

enum LiabilityKind {
  MORTGAGE
  HARD_MONEY
  LINE_OF_CREDIT
  CREDIT_CARD
  OTHER
}

// Outside debt only — money owed to third parties (banks, hard-money
// lenders, card issuers). Partner-funded debt stays in Contribution as
// kind=LOAN; the company dashboard sums both but reports them separately.
model Liability {
  id           String        @id @default(cuid())
  name         String // lender, e.g. "Anchor Capital"
  kind         LiabilityKind @default(OTHER)
  balance      Decimal       @db.Decimal(12, 2) // current outstanding principal
  interestRate Decimal?      @db.Decimal(5, 3)
  propertyId   String? // null = company-level debt, not tied to one property
  // SetNull mirrors BankTxn (spec §5): deleting a property must not silently
  // erase a debt that still genuinely exists.
  property     Property?     @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  notes        String?
  updatedAt    DateTime      @updatedAt
}

model Contribution {
  id          String      @id @default(cuid())
  date        DateTime    @db.Date
  partnerId   String
  partner     Partner     @relation(fields: [partnerId], references: [id])
  propertyId  String
  property    Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  kind        ContribKind
  amount      Decimal     @db.Decimal(12, 2)
  description String?
}
